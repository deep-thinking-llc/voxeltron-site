<!-- ════════════════ SCROLL REVEAL + TERMINAL ANIMATION ════════════════ -->
<script>
  // ── Staggered fadeInUp on page load ──────────────────────────────────
  const allReveals = document.querySelectorAll<HTMLElement>('.reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.06, rootMargin: '0px 0px -20px 0px' }
  );
  allReveals.forEach((el) => observer.observe(el));

  // ── Terminal typing animation ─────────────────────────────────────────
  interface TermLine {
    type: 'command' | 'success' | 'info' | 'warn' | 'blank';
    text?: string;
  }

  const sessions: TermLine[][] = [
    [
      { type: 'command', text: 'curl -sSL https://voxeltron.dev/install.sh | bash' },
      { type: 'success', text: '  installed voxeltron v1.0.0 and voxeltrond v1.0.0' },
      { type: 'blank' },
      { type: 'command', text: 'voxeltrond start' },
      { type: 'success', text: '  daemon started  gRPC on :7443  proxy on :80/:443' },
      { type: 'blank' },
      { type: 'command', text: 'voxeltron' },
      { type: 'success', text: '  connected  0 services running  uptime 0s' },
    ],
    [
      { type: 'command', text: 'voxeltron deploy --source github.com/you/my-app' },
      { type: 'info',    text: '  cloning repository...' },
      { type: 'info',    text: '  building with nixpacks (detected: next.js 14)...' },
      { type: 'info',    text: '  image built in 23s  182MB' },
      { type: 'info',    text: '  zero-downtime route swap via pingora...' },
      { type: 'success', text: '  deployed  https://my-app.yourdomain.com' },
      { type: 'success', text: '  tls cert issued via lets encrypt (0.4s)' },
    ],
    [
      { type: 'command', text: 'voxeltron db provision postgres --version 16' },
      { type: 'info',    text: '  provisioning postgresql 16...' },
      { type: 'success', text: '  running on internal port 5432' },
      { type: 'success', text: '  DATABASE_URL injected (encrypted, never logged)' },
      { type: 'blank' },
      { type: 'command', text: 'voxeltron db backup --now' },
      { type: 'success', text: '  backup complete  14.2MB  stored to s3' },
    ],
    [
      { type: 'command', text: '# press ctrl+a to open the AI agent' },
      { type: 'blank' },
      { type: 'info',    text: '  voxeltron ai — context loaded' },
      { type: 'info',    text: '  logs: 2,481 entries  metrics: 24h  deploys: 12' },
      { type: 'info',    text: '  > why does web-app keep OOMing?' },
      { type: 'warn',    text: '  hypothesis: next.js ISR cache unbounded growth' },
      { type: 'warn',    text: '  evidence: memory 256MB limit, RSS climbing 8MB/hr' },
      { type: 'warn',    text: '  fix: set --memory 512mb. apply? [y/n]' },
      { type: 'success', text: '  fix applied. redeploying...' },
      { type: 'success', text: '  insight saved to knowledge base for next time.' },
    ],
  ];

  let sessionIdx = 0;
  const sleep = (ms: number) => new Promise<void>((r) => setTimeout(r, ms));

  async function runTerminal(container: HTMLElement): Promise<void> {
    while (true) {
      while (container.firstChild) container.removeChild(container.firstChild);

      const lines = sessions[sessionIdx % sessions.length];
      sessionIdx++;

      for (const line of lines) {
        if (line.type === 'blank') {
          container.appendChild(document.createElement('br'));
          await sleep(200);
          continue;
        }

        const lineEl = document.createElement('div');
        lineEl.style.cssText = 'margin-bottom: 2px; white-space: pre-wrap; word-break: break-all;';

        if (line.type === 'command') {
          const prompt = document.createElement('span');
          prompt.className = 'term-prompt';
          prompt.textContent = '$ ';
          lineEl.appendChild(prompt);
        }

        const textEl = document.createElement('span');
        const classMap: Record<string, string> = {
          command: 'term-cmd',
          success: 'term-success',
          info: 'term-info',
          warn: 'term-warn',
        };
        textEl.className = classMap[line.type] ?? 'term-cmd';
        lineEl.appendChild(textEl);

        const cursor = document.createElement('span');
        cursor.className = 'term-cursor';
        lineEl.appendChild(cursor);
        container.appendChild(lineEl);
        container.scrollTop = container.scrollHeight;

        const chars = (line.text ?? '').split('');
        const speed = line.type === 'command' ? 40 : 12;

        for (const ch of chars) {
          textEl.textContent = (textEl.textContent ?? '') + ch;
          container.scrollTop = container.scrollHeight;
          await sleep(speed + Math.random() * speed * 0.5);
        }

        cursor.remove();
        await sleep(line.type === 'command' ? 420 : 70);
      }

      const endCursor = document.createElement('span');
      endCursor.className = 'term-cursor';
      container.appendChild(endCursor);
      await sleep(3800);
    }
  }

  const heroTerm = document.getElementById('hero-terminal');
  if (heroTerm) runTerminal(heroTerm);
</script>
