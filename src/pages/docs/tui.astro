    <a href="/docs/first-deployment" style="color: var(--color-muted); text-decoration: none; font-size: 0.9rem;">
      &larr; First Deployment
    </a>
  </fragment>

  <fragment slot="next">
    <a href="/docs/databases" style="color: var(--color-teal); text-decoration: none; font-size: 0.9rem;">
