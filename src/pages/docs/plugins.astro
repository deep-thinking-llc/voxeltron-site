    <a href="/docs/runbooks" style="color: var(--color-muted); text-decoration: none; font-size: 0.9rem;">
      &larr; Runbooks &amp; Skills
  </fragment>

  <fragment slot="next">
    <a href="/docs/domains-tls" style="color: var(--color-teal); text-decoration: none; font-size: 0.9rem;">
